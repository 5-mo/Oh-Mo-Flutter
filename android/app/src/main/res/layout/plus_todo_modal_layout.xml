<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/plus_modal_bg">

    <TextView
        android:id="@+id/text_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="월"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="47dp"
        android:layout_marginStart="72dp" />

    <EditText
        android:id="@+id/edit_month"
        android:layout_width="37dp"
        android:layout_height="wrap_content"
        android:hint="MM"
        android:inputType="number"
        android:maxLength="2"
        android:textSize="16sp"
        android:textColor="#000000"
        android:textColorHint="#888888"
        android:gravity="center"
        android:background="@null"
        app:layout_constraintTop_toBottomOf="@+id/text_month"
        app:layout_constraintStart_toStartOf="@+id/text_month"
        app:layout_constraintEnd_toEndOf="@+id/text_month"
        android:layout_marginTop="7dp" />

    <TextView
        android:id="@+id/text_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="일"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/text_month"
        android:layout_marginTop="47dp"
        android:layout_marginStart="64dp" />

    <EditText
        android:id="@+id/edit_day"
        android:layout_width="37dp"
        android:layout_height="wrap_content"
        android:hint="DD"
        android:inputType="number"
        android:maxLength="2"
        android:textSize="16sp"
        android:textColor="#000000"
        android:textColorHint="#888888"
        android:gravity="center"
        android:background="@null"
        app:layout_constraintTop_toBottomOf="@+id/text_day"
        app:layout_constraintStart_toStartOf="@+id/text_day"
        app:layout_constraintEnd_toEndOf="@+id/text_day"
        android:layout_marginTop="7dp" />

    <FrameLayout
        android:id="@+id/time_picker_frame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="47dp"
        android:layout_marginEnd="50dp"
        android:background="@drawable/rounded_white_button_bg"
        android:clickable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@+id/edit_day"
        app:layout_constraintTop_toTopOf="parent">

        <EditText
            android:id="@+id/edit_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginVertical="10dp"
            android:background="@null"
            android:cursorVisible="false"
            android:focusable="false"
            android:gravity="center"
            android:hint="시간 추가"
            android:textSize="14sp"
            android:textColor="#000000"
            android:textColorHint="#888888"/>
    </FrameLayout>

    <EditText
        android:id="@+id/edit_content"
        android:layout_width="match_parent"
        android:layout_height="77dp"
        android:textSize="16sp"
        android:gravity="center"
        android:background="@drawable/list_bg"
        android:textColor="#000000"
        android:textColorHint="#888888"
        app:layout_constraintTop_toBottomOf="@+id/edit_day"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="18dp"
        android:layout_marginStart="50dp"
        android:layout_marginEnd="50dp"/>

    <Button
        android:id="@+id/confirm_button"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="완료"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:background="@drawable/rounded_black_button_bg"
        app:layout_constraintTop_toBottomOf="@+id/edit_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="17dp"
        android:layout_marginStart="50dp"
        android:layout_marginEnd="50dp"
        android:layout_marginBottom="16dp"/>


</androidx.constraintlayout.widget.ConstraintLayout>