<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 그림자 레이어 (아래에 배치) -->
    <item android:bottom="1dp"> <!-- box-shadow의 offset-y: 1px 반영 (아래로 1dp 밀기) -->
        <shape android:shape="rectangle">
            <corners android:radius="18.5dp" />
            <solid android:color="#12000000" /> <!-- 그림자 색상 -->
        </shape>
    </item>

    <!-- 실제 배경 레이어 (위에 배치) -->
    <item android:bottom="1dp"> <!-- 그림자 레이어와 동일하게 아래로 1dp 밀어서 그림자 효과 유지 -->
        <shape android:shape="rectangle">
            <corners android:radius="18.5dp" />
            <solid android:color="#ffffff" />
            <stroke android:width="1dp" android:color="#E5E5E5" />
        </shape>
    </item>
</layer-list>